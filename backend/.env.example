NODE_ENV=development
PORT=4000

DATABASE_URL="postgresql://taskuser:taskpass@db:5432/taskmanager"

REDIS_URL="redis://redis:6379"

JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

FRONTEND_URL=http://localhost:3333

TOTP_APP_NAME=TaskManager

VAPID_PUBLIC_KEY=generate-with-npx-web-push-generate-vapid-keys
VAPID_PRIVATE_KEY=generate-with-npx-web-push-generate-vapid-keys
VAPID_EMAIL=mailto:admin@yourdomain.com

# Admin Configuration (comma-separated list of admin emails)
ADMIN_EMAILS=admin@yourdomain.com
